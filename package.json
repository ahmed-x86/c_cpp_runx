{
  "name": "c-cpp-runx",
  "displayName": "C/C++ RunX",
  "description": "The ultimate C/C++ runner & compiler by ahmed-x86. Instantly run, execute, and compile C and C++ code using GCC, G++, or TCC.",
  "version": "1.0.7",
  "publisher": "ahmed-x86",
  "icon": "icon.png",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmed-x86/c-cpp-runx.git"
  },
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "c c++ cpp c/c++",
    "runner run execute",
    "compiler compile build",
    "gcc g++ tcc",
    "ahmed ahmed-x86"
  ],
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp",
    "onCommand:c-cpp-runx.showMenu",
    "onCommand:c-cpp-runx.showTestMenu",
    "onCommand:c-cpp-runx.runC",
    "onCommand:c-cpp-runx.runCpp"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "c-cpp-runx.showMenu",
        "title": "C/C++ RunX: Build & Run Menu",
        "icon": "$(zap)"
      },
      {
        "command": "c-cpp-runx.runC",
        "title": "C/C++ RunX: Run C File"
      },
      {
        "command": "c-cpp-runx.runCpp",
        "title": "C/C++ RunX: Run C++ File"
      },
      {
        "command": "c-cpp-runx.showTestMenu",
        "title": "C/C++ RunX: Settings (Compiler)",
        "icon": "$(gear)"
      }
    ],
    "snippets": [
      {
        "language": "c",
        "path": "./snippets/snippets.json"
      },
      {
        "language": "cpp",
        "path": "./snippets/snippets.json"
      }
    ],
    "keybindings": [
      {
        "command": "c-cpp-runx.showMenu",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus && (resourceLangId == c || resourceLangId == cpp)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "c-cpp-runx.showMenu",
          "group": "navigation@1",
          "when": "resourceLangId == c || resourceLangId == cpp"
        }
      ],
      "editor/title": [
        {
          "command": "c-cpp-runx.showTestMenu",
          "group": "navigation@2",
          "when": "resourceLangId == c || resourceLangId == cpp"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.108.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}